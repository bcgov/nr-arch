        </mxCell>
        <mxCell id="a2" edge="1" parent="1" source="d1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;fontSize=11;fontStyle=1;flowAnimation=1;" target="d2-oracle" value="Oracle">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" edge="1" parent="1" source="d1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;fontStyle=1;flowAnimation=1;" target="dab-rec" value="SQL Server">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5" edge="1" parent="1" source="d2-oracle" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=1;flowAnimation=1;" target="ords-rec" value="Yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a6" edge="1" parent="1" source="d2-oracle" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#cc0000;strokeWidth=2;fontSize=11;fontStyle=1;flowAnimation=1;" target="d3" value="No">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a7" edge="1" parent="1" source="d3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;flowAnimation=1;" target="ords-rec" value="Yes → still ORDS">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="280" y="590" />
              <mxPoint x="280" y="590" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a8" edge="1" parent="1" source="d3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;strokeWidth=2;fontSize=11;fontStyle=1;flowAnimation=1;" target="db2rest-rec" value="No">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deploy-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="&lt;b&gt;Deployment Recommendation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;All tools → Docker containers on &lt;b&gt;Azure Container Apps (Consumption)&lt;/b&gt;&lt;br&gt;Lowest cost · Zero ops · Scale-to-zero · VNet + ExpressRoute&lt;br&gt;Use AKS Automatic only if OraOperator / K8s CRDs are required.&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="430" x="600" y="530" as="geometry" />
        </mxCell>
        <mxCell id="rule" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;One-Line Rule:&lt;/b&gt; Use this architecture to expose legacy databases as governed, real-time data APIs.&lt;br&gt;Do &lt;b&gt;not&lt;/b&gt; use it to build domain or business APIs." vertex="1">
