<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.3.6 Chrome/140.0.7339.249 Electron/38.8.0 Safari/537.36" version="29.3.6">
  <diagram id="decision-flow" name="Tool Selection Decision Flow">
    <mxGraphModel dx="1426" dy="841" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontColor=#333333;" value="&lt;b&gt;API Runtime Tool Selection — Decision Flow&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#888&quot;&gt;Which tool to use based on database type, requirements, and geospatial needs&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="600" x="350" y="10" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" value="&lt;b&gt;Start&lt;/b&gt;&lt;br&gt;Need to expose&lt;br&gt;legacy DB as API" vertex="1">
          <mxGeometry height="80" width="150" x="580" y="70" as="geometry" />
        </mxCell>
        <mxCell id="d1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" value="&lt;b&gt;Which source&lt;br&gt;database?&lt;/b&gt;" vertex="1">
          <mxGeometry height="100" width="180" x="565" y="190" as="geometry" />
        </mxCell>
        <mxCell id="d2-oracle" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;Oracle DBA&lt;br&gt;available &amp;amp;&lt;br&gt;Oracle Support&lt;br&gt;contracted?&lt;/b&gt;" vertex="1">
          <mxGeometry height="120" width="180" x="160" y="340" as="geometry" />
        </mxCell>
        <mxCell id="ords-rec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" value="&lt;b&gt;Oracle ORDS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;✓ $0 (bundled with Oracle DB)&lt;br&gt;✓ Oracle Premier Support&lt;br&gt;✓ REST + GraphQL + SODA&lt;br&gt;✓ Best Oracle Spatial support&lt;br&gt;✓ GeoJSON / WKT native&lt;br&gt;✓ PL/SQL gateway&lt;/font&gt;" vertex="1">
          <mxGeometry height="140" width="210" x="30" y="530" as="geometry" />
        </mxCell>
        <mxCell id="d3" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;Need GraphQL,&lt;br&gt;SODA, APEX, or&lt;br&gt;PL/SQL gateway?&lt;/b&gt;" vertex="1">
          <mxGeometry height="120" width="180" x="310" y="530" as="geometry" />
        </mxCell>
        <mxCell id="db2rest-rec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;dashed=1;" value="&lt;b&gt;DB2Rest&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(Fallback for Oracle)&lt;br&gt;✓ Apache 2.0&lt;br&gt;✓ Zero DB footprint&lt;br&gt;✓ Multi-DB support&lt;br&gt;✓ REST only&lt;br&gt;⚠ Geo needs POC&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="200" x="310" y="720" as="geometry" />
        </mxCell>
        <mxCell id="dab-rec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" value="&lt;b&gt;Microsoft DAB&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;✓ MIT License&lt;br&gt;✓ Microsoft-supported&lt;br&gt;✓ Fabric-native&lt;br&gt;✓ REST + GraphQL&lt;br&gt;✓ Config-driven JSON&lt;br&gt;✓ WKT spatial support&lt;br&gt;✓ OpenAPI 3 auto-gen&lt;/font&gt;" vertex="1">
          <mxGeometry height="150" width="210" x="840" y="340" as="geometry" />
        </mxCell>
        <mxCell id="geo-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#b85450;arcSize=6;" value="" vertex="1">
          <mxGeometry height="170" width="480" x="600" y="700" as="geometry" />
        </mxCell>
        <mxCell id="geo-title" parent="1" style="text;html=1;align=center;fontSize=13;fontColor=#b85450;" value="&lt;b&gt;Geospatial Decision Rule&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="280" x="700" y="705" as="geometry" />
        </mxCell>
        <mxCell id="geo1" parent="1" style="text;html=1;align=left;fontSize=11;" value="&lt;b&gt;Oracle Spatial is authoritative?&lt;/b&gt; → &lt;font color=&quot;#b85450&quot;&gt;&lt;b&gt;ORDS&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SDO_GEOMETRY, GeoJSON, WKT — first-class support&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="440" x="620" y="735" as="geometry" />
        </mxCell>
        <mxCell id="geo2" parent="1" style="text;html=1;align=left;fontSize=11;" value="&lt;b&gt;SQL Server spatial + WKT acceptable?&lt;/b&gt; → &lt;font color=&quot;#6c8ebf&quot;&gt;&lt;b&gt;DAB&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;geometry/geography as WKT strings — consumers convert client-side&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="440" x="620" y="775" as="geometry" />
        </mxCell>
        <mxCell id="geo3" parent="1" style="text;html=1;align=left;fontSize=11;" value="&lt;b&gt;Need validation before committing?&lt;/b&gt; → &lt;font color=&quot;#999999&quot;&gt;&lt;b&gt;DB2Rest / Faucet + POC&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;No documented spatial-first behavior — validate with proof of concept&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="440" x="620" y="815" as="geometry" />
        </mxCell>
        <mxCell id="a1" edge="1" parent="1" source="start" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;flowAnimation=1;" target="d1">
