<mxfile host="Confluence" modified="2026-04-15" agent="Copilot" version="21.0">
  <diagram id="ords-routing" name="ORDS Internal Routing — Per DB Host, Not Per Schema">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;ORDS Internal Routing — One Container Per DB Host&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#888&quot;&gt;Multiple schemas served from a single ORDS instance via URL path aliases&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="600" height="50" as="geometry" />
        </mxCell>

        <!-- Incoming HTTP Request -->
        <mxCell id="request" value="&lt;b&gt;HTTP Request&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;GET /ords/&lt;b&gt;nrm&lt;/b&gt;/employees&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="230" height="60" as="geometry" />
        </mxCell>

        <!-- ORDS Container -->
        <mxCell id="ords-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#b85450;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="340" y="80" width="440" height="350" as="geometry" />
        </mxCell>
        <mxCell id="ords-title" value="&lt;b&gt;ORDS Container (ACA)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Single instance per Oracle DB host&lt;/font&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="400" y="85" width="320" height="35" as="geometry" />
        </mxCell>

        <!-- Step 1: Parse URL -->
        <mxCell id="step1" value="&lt;b&gt;① Parse URL Path&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;font-family:monospace&quot;&gt;/ords/{schema_alias}/{resource}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="130" width="270" height="50" as="geometry" />
        </mxCell>

        <!-- Step 2: Schema Lookup -->
        <mxCell id="step2" value="&lt;b&gt;② Schema Alias Lookup&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Alias &quot;nrm&quot; → Oracle user NRM_DATA&lt;br&gt;(from ORDS_METADATA)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="200" width="270" height="55" as="geometry" />
        </mxCell>

        <!-- Step 3: Proxy Connect -->
        <mxCell id="step3" value="&lt;b&gt;③ Proxy Connect&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ORDS_PUBLIC_USER →&lt;br&gt;proxy-connects to NRM_DATA&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="275" width="270" height="55" as="geometry" />
        </mxCell>

        <!-- Step 4: Execute -->
        <mxCell id="step4" value="&lt;b&gt;④ Execute Query / PL/SQL&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Runs as NRM_DATA user context&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="350" width="270" height="50" as="geometry" />
        </mxCell>

        <!-- Internal arrows -->
        <mxCell id="i1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=1;flowAnimation=1;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="i2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=1;flowAnimation=1;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="i3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=1;flowAnimation=1;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Oracle Database -->
        <mxCell id="oracle-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d79b00;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="880" y="80" width="500" height="400" as="geometry" />
        </mxCell>
        <mxCell id="oracle-title" value="&lt;b&gt;Oracle Database (On-Prem)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Single DB / PDB — multiple ORDS-enabled schemas&lt;/font&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#7a5900;" vertex="1" parent="1">
          <mxGeometry x="920" y="85" width="420" height="35" as="geometry" />
        </mxCell>

        <!-- ORDS_METADATA -->
        <mxCell id="metadata" value="&lt;b&gt;ORDS_METADATA&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;API definitions, modules,&lt;br&gt;templates, handlers,&lt;br&gt;OAuth clients&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="130" width="180" height="90" as="geometry" />
        </mxCell>

        <!-- ORDS_PUBLIC_USER -->
        <mxCell id="pubuser" value="&lt;b&gt;ORDS_PUBLIC_USER&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Single DB user for all connections&lt;br&gt;Proxy-connects to target schemas&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="240" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Schema boxes -->
        <mxCell id="schema1" value="&lt;b&gt;NRM_DATA&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;alias: /ords/&lt;b&gt;nrm&lt;/b&gt;/...&lt;br&gt;parcels, tenures, boundaries&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="340" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="schema2" value="&lt;b&gt;WATER_DATA&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;alias: /ords/&lt;b&gt;water&lt;/b&gt;/...&lt;br&gt;water rights, licences&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1090" y="340" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="schema-more" value="&lt;font style=&quot;font-size:11px&quot;&gt;... more schemas ...&lt;/font&gt;" style="text;html=1;align=center;fontSize=11;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1270" y="370" width="100" height="30" as="geometry" />
        </mxCell>

        <!-- Proxy arrows -->
        <mxCell id="p1" value="proxy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=1;dashed=1;fontSize=9;flowAnimation=1;" edge="1" parent="1" source="pubuser" target="schema1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="proxy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=1;dashed=1;fontSize=9;flowAnimation=1;" edge="1" parent="1" source="pubuser" target="schema2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Main flow arrows -->
        <mxCell id="m1" value="ACA internal ingress" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;fontSize=10;flowAnimation=1;" edge="1" parent="1" source="request" target="step1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="JDBC over ExpressRoute" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;flowAnimation=1;" edge="1" parent="1" source="step4" target="pubuser">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="810" y="375" />
              <mxPoint x="810" y="275" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- JSON Response -->
        <mxCell id="response" value="&lt;b&gt;⑤ JSON Response&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Back to consumer via HTTP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;dashed=1;flowAnimation=1;" edge="1" parent="1" source="step4" target="response">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="350" y="375" />
              <mxPoint x="350" y="265" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Key facts -->
        <mxCell id="facts-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="40" y="530" width="600" height="130" as="geometry" />
        </mxCell>
        <mxCell id="facts-title" value="&lt;b&gt;Key Architecture Facts&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="55" y="535" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f1t" value="• One ORDS container per Oracle DB host — NOT per schema" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="558" width="550" height="18" as="geometry" />
        </mxCell>
        <mxCell id="f2t" value="• ORDS_PUBLIC_USER proxy-connects to each enabled schema at runtime" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="578" width="550" height="18" as="geometry" />
        </mxCell>
        <mxCell id="f3t" value="• Each schema enabled via ORDS.ENABLE_SCHEMA() with a URL mapping pattern" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="598" width="550" height="18" as="geometry" />
        </mxCell>
        <mxCell id="f4t" value="• One ORDS container CAN connect to multiple DBs via &quot;database pools&quot;" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="618" width="550" height="18" as="geometry" />
        </mxCell>
        <mxCell id="f5t" value="• For isolation: use separate ORDS container apps per business domain, not per schema" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="638" width="550" height="18" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
